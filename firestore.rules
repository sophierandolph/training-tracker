rules_version = '2';

// Training Tracker Firestore Security Rules
// Deploy via Firebase Console > Firestore > Rules
//
// Uses Google sign-in. Only randolph.sophia@gmail.com can access data.
// The email check uses request.auth.token.email which Firebase populates
// from the Google sign-in provider.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'randolph.sophia@gmail.com';
    }

    match /workouts/{docId} {
      allow read, write: if isOwner();
    }

    match /fuelLogs/{docId} {
      allow read, write: if isOwner();
    }

    match /coachSessions/{docId} {
      allow read, write: if isOwner();
    }

    match /userData/{docId} {
      allow read, write: if isOwner();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
