rules_version = '2';

// Training Tracker Firestore Security Rules
// Deploy via Firebase Console > Firestore > Rules
//
// How this works:
// - App uses Firebase Anonymous Auth (no login screen)
// - On first visit, a unique anonymous UID is created and persisted in the browser
// - These rules lock all reads/writes to that one UID
// - Anyone else who visits the URL gets a DIFFERENT anonymous UID and can't access your data
//
// IMPORTANT: After deploying these rules, you need to set YOUR anonymous UID
// in the rules below. Steps:
// 1. Open the app in your browser (the one you normally use)
// 2. Open browser console (Cmd+Option+J on Mac)
// 3. Type: firebase.auth().currentUser.uid
// 4. Copy that UID string
// 5. Replace x07FO5MVDJMJFB63He23GW3ohDG2 below with your actual UID
// 6. Re-deploy rules in Firebase Console

service cloud.firestore {
  match /databases/{database}/documents {

    // Workouts collection
    match /workouts/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'x07FO5MVDJMJFB63He23GW3ohDG2';
    }

    // Fuel logs collection
    match /fuelLogs/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'x07FO5MVDJMJFB63He23GW3ohDG2';
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
